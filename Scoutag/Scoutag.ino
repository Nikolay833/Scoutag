/* ===== FUNCTIONS ===== */

void goToSleep() {
  tft.fillScreen(ST77XX_BLACK);
  digitalWrite(TFT_BL, LOW);
  esp_sleep_enable_ext0_wakeup(GPIO_NUM_27, 0); // Wake on GND (Button press)
  esp_deep_sleep_start();
}

void drawSprite(int16_t x, int16_t y, const uint8_t *bitmap, int16_t w, int16_t h, uint16_t color, uint16_t bg) {
  uint16_t buf[w]; 
  int16_t byteWidth = (w + 7) / 8;
  tft.startWrite();
  tft.setAddrWindow(x, y, w, h);
  for (int16_t row = 0; row < h; row++) {
    for (int16_t col = 0; col < w; col++) {
      uint8_t byte = pgm_read_byte(bitmap + row * byteWidth + col / 8);
      buf[col] = (byte & (0x80 >> (col % 8))) ? color : bg;
    }
    tft.writePixels(buf, w);
  }
  tft.endWrite();
}

void setup() {
	Serial.begin(115200);
  pinMode(TFT_BL, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  // Initialize SPI and TFT FIRST (before anything that might call goToSleep)
  SPI.begin(TFT_SCK, TFT_MISO, TFT_MOSI);
  tft.init(170, 320);
  tft.setRotation(1);
  tft.fillScreen(ST77XX_BLACK);

  // 1. HOLD TO TURN ON (2 SECONDS)
  // Wait a moment for the pin to settle after wake
  delay(100);

  // Check if button is being held down
  if (digitalRead(BUTTON_PIN) == LOW) {
    // Button is pressed, wait for 2 second hold
    unsigned long startCheck = millis();
    while (digitalRead(BUTTON_PIN) == LOW) {
      if (millis() - startCheck > 2000) break;
    }
    // If they released before 2s, go back to sleep
    if (millis() - startCheck < 2000) goToSleep();
  } else {
    // Button not pressed at all, go back to sleep
    goToSleep();
  }

  digitalWrite(TFT_BL, HIGH);

  drawSprite(5, 30, lcd_text, 311, 100, ST77XX_WHITE, ST77XX_BLACK);
  previousMillis = millis();
}

void loop() {
  unsigned long currentMillis = millis();
  int btn = digitalRead(BUTTON_PIN);

  // --- GLOBAL BUTTON TRACKING ---
  if (btn == LOW && !isButtonPressed) {
    buttonTimer = currentMillis;
    isButtonPressed = true;
  } else if (btn == HIGH && isButtonPressed) {
    long duration = currentMillis - buttonTimer;
    if (duration > 50 && duration < 500 && state == 3) state = 4; // Scan
    if (duration > 2000) state = 5; // Shutdown Animation
    isButtonPressed = false;
  }

  // --- STATE MACHINE ---
  switch (state) {
    case 0: // BOOT TEXT (3s)
      if (currentMillis - previousMillis >= 3000) {
        tft.fillScreen(ST77XX_BLACK);
        previousMillis = currentMillis;
        state = 1;
      }
      break;

    case 1: // REPEAT ANIMATION (12-16 twice)
      if (currentMillis - previousMillis >= 200) {
        previousMillis = currentMillis;
        drawSprite(10, 20, animationFrames[i], 140, 140, ST77XX_WHITE, ST77XX_BLACK);
        i++;
        if (i >= 16) { i = 11; j--; }
        if (j <= 0) state = 2;
      }
      break;

    case 2: // REVERSE ANIMATION (11 to 0)
      if (currentMillis - previousMillis >= 150) {
        previousMillis = currentMillis;
        drawSprite(10, 20, animationFrames[k], 140, 140, ST77XX_WHITE, ST77XX_BLACK);
        k--;
        if (k < 0) { 
          state = 3; 
          tft.setCursor(165,55); 
          tft.setTextColor(ST77XX_WHITE);
          tft.setTextSize(2);
          tft.println("Press once");
          tft.setCursor(165, 75);
          tft.println("to activate");
          tft.setCursor(165, 95);
          tft.println("sniff mode!");
        }
      }
      break;

    case 3: // HOME SCREEN (IDLE)
      break;

    case 4: // SCANNING ANIMATION + LOGIC
      // Simple scan animation frame
			tft.fillScreen(ST77XX_BLACK);
      drawSprite(10, 20, animationFrames[16], 140, 140, ST77XX_WHITE, ST77XX_BLACK);
      
      tft.setCursor(168, 55); tft.setTextColor(ST77XX_WHITE); tft.println("SNIFFING...");
      
      runEvilTwinDetection(); // This handles the scan and displays results
      state = 3;
      break;

    case 5: // SHUTDOWN ANIMATION
      for (int s = 0; s <= 15; s++) {
        drawSprite(10, 20, animationFrames[s], 140, 140, ST77XX_WHITE, ST77XX_BLACK);
        delay(100);
      }
			tft.fillScreen(ST77XX_BLACK);
			tft.setCursor(40, 65);
			tft.setTextSize(5);
			tft.setTextColor(ST77XX_WHITE);

			tft.println("Goodbye!");
			delay(1000);
      goToSleep();
      break;
  }
}

